.article
  margin: 30px 0

.article-inner
  @extend $block
  overflow: hidden

.article-header
  padding: 30px 35px 0

.article-title
  text-decoration: none
  font-size: 1.8em
  font-weight: 600
  color: color-default
  line-height: 1.4
  transition: color 0.2s
  a&:hover
    color: color-link

.article-entry
  @extend $base-style
  clearfix()
  color: color-default
  padding: 0 35px 20px
  p, table
    line-height: 1.8
    margin: 1.2em 0
  h1, h2, h3, h4, h5, h6
    font-weight: 600
    line-height: 1.4
    margin: 1.4em 0 0.6em
  h1
    font-size: 1.6em
    border-bottom: 2px solid #f0f0f0
    padding-bottom: 10px
  h2
    font-size: 1.3em
    border-bottom: 1px solid #f0f0f0
    padding-bottom: 8px
  h3
    font-size: 1.1em
  a
    color: color-link
    text-decoration: none
    &:hover
      text-decoration: underline
  ul, ol, dl
    margin-top: 1em
    margin-bottom: 1em
    padding-left: 20px
  li
    margin: 0.3em 0
  img, video
    max-width: 100%
    height: auto
    display: block
    margin: 20px auto
    border-radius: 8px
    box-shadow: 0 2px 12px rgba(0,0,0,0.08)
  iframe
    border: none
  table
    width: 100%
    border-collapse: collapse
    border-spacing: 0
    font-size: 0.93em
  th
    font-weight: 600
    border-bottom: 2px solid #e0e4ea
    padding: 10px 12px
    background: #f8f9fc
    text-align: left
  td
    border-bottom: 1px solid #e8ecf0
    padding: 8px 12px
  tr:last-child td
    border-bottom: none
  blockquote
    border-left: 4px solid color-link
    margin: 1.5em 0
    padding: 12px 20px
    background: #f8f9fc
    border-radius: 0 6px 6px 0
    color: #666
    footer
      font-size: font-size
      margin: 0.5em 0 0
      cite
        &:before
          content: "—"
          padding: 0 0.5em
  code
    background: #f0f3f9
    padding: 2px 7px
    border-radius: 4px
    font-size: 0.9em
    color: #e03e3e
  pre
    background: #282c34
    border-radius: 8px
    padding: 16px 20px
    overflow-x: auto
    margin: 1.2em 0
    code
      background: none
      color: #abb2bf
      padding: 0
      border-radius: 0
      font-size: 0.85em
  .caption
    color: color-grey
    display: block
    font-size: 0.9em
    margin-top: 0.5em
    position: relative
    text-align: center

.article-more-link a
  display: inline-block
  line-height: 1em
  padding: 6px 15px
  border-radius: 15px
  background: color-background
  color: color-grey
  text-decoration: none
  &:hover
    background: color-link
    color: #fff
    text-decoration: none

.article-footer
  clearfix()
  font-size: 0.85em
  line-height: line-height
  border-top: 1px solid color-border
  padding-top: line-height
  margin: 0 article-padding article-padding
  a
    color: color-grey
    text-decoration: none
    &:hover
      color: color-default

.article-tag-list-item
  float: left
  margin-right: 10px

.article-tag-list-link
  &:before
    content: "#"

.article-comment-link
  float: right
  &:before
    padding-right: 8px

.article-share-link
  cursor: pointer
  float: right
  margin-left: 20px
  &:before
    padding-right: 6px

#article-nav
  clearfix()
  position: relative
  margin: 20px 0
  @media mq-normal
    &:before
      absolute-center(8px)
      content: ""
      border-radius: 50%
      background: color-border

.article-nav-link-wrap
  text-decoration: none
  color: color-grey
  box-sizing: border-box
  margin-top: 20px
  text-align: center
  display: block
  &:hover
    color: color-default
  @media mq-normal
    width: 50%
    margin-top: 0

#article-nav-newer
  @media mq-normal
    float: left
    text-align: right
    padding-right: 20px

#article-nav-older
  @media mq-normal
    float: right
    text-align: left
    padding-left: 20px

.article-nav-caption
  text-transform: uppercase
  letter-spacing: 2px
  color: color-border
  line-height: 1em
  font-weight: bold
  #article-nav-newer &
    margin-right: -2px

.article-nav-title
  font-size: 0.85em
  line-height: line-height
  margin-top: 0.5em

.article-share-box
  position: absolute
  display: none
  background: #fff
  box-shadow: 1px 2px 10px rgba(0, 0, 0, 0.2)
  border-radius: 3px
  margin-left: -145px
  overflow: hidden
  z-index: 1
  &.on
    display: block

.article-share-input
  width: 100%
  background: none
  box-sizing: border-box
  font: 14px font-sans
  padding: 0 15px
  color: color-default
  outline: none
  border: 1px solid color-border
  border-radius: 3px 3px 0 0
  height: 36px
  line-height: 36px

.article-share-links
  clearfix()
  background: color-background

$article-share-link
  width: 50px
  height: 36px
  display: block
  float: left
  position: relative
  color: #999
  text-shadow: 0 1px #fff
  .fa
    font-size: 20px
    absolute-center(@font-size)
    text-align: center
  &:hover
    color: #fff

.article-share-twitter
  @extend $article-share-link
  &:hover
    background: color-twitter
    text-shadow: 0 1px darken(color-twitter, 20%)

.article-share-facebook
  @extend $article-share-link
  &:hover
    background: color-facebook
    text-shadow: 0 1px darken(color-facebook, 20%)

.article-share-pinterest
  @extend $article-share-link
  &:hover
    background: color-pinterest
    text-shadow: 0 1px darken(color-pinterest, 20%)

.article-share-linkedin
  @extend $article-share-link
  &:hover
    background: color-linkedin
    text-shadow: 0 1px darken(color-linkedin, 20%)
