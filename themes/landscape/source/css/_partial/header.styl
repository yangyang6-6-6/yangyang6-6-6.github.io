#header
  height: banner-height
  position: relative
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%)
  &:before, &:after
    content: ""
    position: absolute
    left: 0
    right: 0
    height: 40px
  &:before
    top: 0
    background: linear-gradient(rgba(0, 0, 0, 0.15), transparent)
  &:after
    bottom: 0
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.15))

#header-outer
  height: 100%
  position: relative

#header-inner
  position: relative
  overflow: hidden

#banner
  display: none

#header-title
  text-align: center
  height: logo-size
  position: absolute
  top: 50%
  left: 0
  right: 0
  margin-top: logo-size * -0.5

$logo-text
  text-decoration: none
  color: #fff
  font-weight: 600
  text-shadow: 0 2px 8px rgba(0, 0, 0, 0.2)

#logo
  @extend $logo-text
  font-size: 28px
  line-height: 1.4
  letter-spacing: 1px

#subtitle
  @extend $logo-text
  font-size: subtitle-size
  line-height: subtitle-size
  font-weight: 300
  opacity: 0.85

#subtitle-wrap
  margin-top: 10px

#main-nav
  float: left
  margin-left: -15px

$nav-link
  float: left
  color: #fff
  opacity: 0.7
  text-decoration: none
  text-shadow: 0 1px rgba(0, 0, 0, 0.2)
  transition: opacity 0.2s
  display: block
  padding: 20px 15px
  &:hover
    opacity: 1

.nav-icon
  @extend $nav-link
  text-align: center
  font-size: font-size
  width: font-size
  height: font-size
  padding: 20px 15px
  position: relative
  cursor: pointer

.main-nav-link
  @extend $nav-link
  font-weight: 400
  letter-spacing: 0.5px
  @media mq-mobile
    display: none

#main-nav-toggle
  display: none
  @media mq-mobile
    display: block

#sub-nav
  float: right
  margin-right: -15px
